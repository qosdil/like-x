ASYNC_POST_LIKE=true
DEBUG=false

# HTTP Server
LIKE_X_HTTP_SERVER_PORT=3000
LIKE_X_POST_PPROF_HTTP_PREFIX="/tmp-pprof"

# PostgreSQL Database
LIKE_X_POSTGRES_HOST=host.docker.internal
LIKE_X_POSTGRES_PORT=5432
LIKE_X_POSTGRES_SSL_MODE=disable
LIKE_X_POSTGRES_USER=postgres
LIKE_X_POSTGRES_PASSWORD=
LIKE_X_POSTGRES_DB_NAME=like_x_post
